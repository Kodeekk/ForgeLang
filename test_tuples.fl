// Test tuple types and destructuring
import [println] from std.io;
import std.list;

fn main() -> int {
    // Test 1: Tuple literal
    var t1: (int, str) = (42, "hello");
    println("Tuple literal: {t1}");

    // Test 2: Tuple destructuring in var declaration
    var (a, b): (int, str) = (100, "swapped");
    println("Destructured: a={a}, b={b}");

    // Test 3: Simple tuple destructuring
    var (x, y): (int, int) = (10, 20);
    println("Destructured: x={x}, y={y}");

    // Test 4: Tuple with underscore (ignore value)
    var (_, important): (str, int) = ("ignored", 99);
    println("Important value: {important}");

    // Test 5: Match on tuple pattern
    var coords: (int, int) = (5, 10);
    match coords {
        (0, 0) => println("At origin"),
        (x, 0) => println("On X-axis at {x}"),
        (0, y) => println("On Y-axis at {y}"),
        (x, y) => println("At position ({x}, {y})")
    }

    // Test 6: Triple tuple
    var triple: (int, str, bool) = (42, "answer", true);
    var (num, text, flag): (int, str, bool) = triple;
    println("Triple: num={num}, text={text}, flag={flag}");

    // Test 7: Parenthesized expression (not a tuple)
    var single: int = (100);
    println("Parenthesized expr: {single}");

    // Test 8: Tuple in for loop
    var pairs: list<(str, int)> = [("a", 1), ("b", 2), ("c", 3)];
    var sum: int = 0;
    for (key, value) in pairs {
        println("  Key: {key}, Value: {value}");
        sum = sum + value;
    }
    println("Sum of values: {sum}");

    println("\nAll tuple tests passed!");
    return 0;
}
